# ─────────────────────────────────────────────────────────────
# AutoDM — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────

# PostgreSQL Database
DATABASE_URL=postgresql://user:password@localhost:5432/autodm

# JWT Secret (use a long random string)
JWT_SECRET=your_super_secret_jwt_key_here

# ─── URLs ──────────────────────────────────────────────────────
# Backend URL (used for OAuth callback + webhook)
# Local dev: http://localhost:4000  |  Production: https://your-api-domain.com
BACKEND_URL=http://localhost:4000

# Frontend URL (used to redirect after OAuth + build booking links)
# Local dev: http://localhost:5173  |  Production: https://your-frontend-domain.com
FRONTEND_URL=http://localhost:5173

# ─── Meta / Instagram API ──────────────────────────────────────
# Get these from: https://developers.facebook.com → Your App → Basic Settings

# Your Facebook App ID
META_APP_ID=your_meta_app_id_here

# Your Facebook App Secret
META_APP_SECRET=your_meta_app_secret_here

# Webhook Verify Token — any random string YOU choose (must match what you enter in Meta Developer portal)
META_WEBHOOK_VERIFY_TOKEN=autodm_webhook_secret_2024

# Permissions needed in Meta App Review:
#   instagram_basic
#   instagram_manage_messages
#   instagram_manage_comments
#   pages_show_list
#   pages_read_engagement
#   pages_messaging
#   business_management
#
# Webhook fields to subscribe (set in Meta App Dashboard → Webhooks → Instagram):
#   messages, messaging_postbacks, message_echoes, messaging_seen
#   comments, mention, feed

# ─── Razorpay (Payments) ───────────────────────────────────────
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ─── Google Calendar ───────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:4000/api/calendar/oauth/callback

# ─── Email (Resend) ────────────────────────────────────────────
RESEND_API_KEY=your_resend_api_key
